# Vite reads .env files from this package's own directory (packages/web/),
# not the repo root — copy this to packages/web/.env for local dev.
# Full reference: TECHNICAL.md §11 "Network flag"; ClaudeCodeInstruction.md Phase 7/10/10b.

# Sets the *initial* network baked into the build (core/network.ts) —
# devnet | testnet | mainnet, default testnet. Since phase 10b the network is
# also runtime state: the top-bar badge lets a visitor switch testnet <-> mainnet,
# and that choice is persisted in the browser's localStorage and overrides this
# default on subsequent visits (only for testnet/mainnet — a devnet build's
# badge is not switchable). Set this to `mainnet` for a production build.
VITE_VERICELL_NETWORK=testnet

# Base URL of a running packages/api instance (no trailing slash, no /api/v1
# suffix). Unset = search/verify fall back to this device's local index only.
VITE_API_URL=http://localhost:3000

# Service fee recipient per network (TECHNICAL.md §7.2-C) — mirrors the
# server-side VERICELL_FEE_ADDRESS_<NETWORK> vars, baked in at build time so
# the browser-built anchor tx can top up the same fee-collection pool.
# Unset = no service fee shown or charged for that network. Never a real
# address in this file.
# VITE_VERICELL_FEE_ADDRESS_TESTNET=ckt1...YOUR_FEE_ADDRESS
# VITE_VERICELL_FEE_ADDRESS_MAINNET=ckb1...YOUR_FEE_ADDRESS
