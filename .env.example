# VeriCell configuration — for the docker-compose.yml stack (Phase 10c).
# Copy to `.env` in the repo root and fill in; `.env` itself is gitignored,
# `docker compose` loads it automatically. Never commit the real file.
# Full reference: TECHNICAL.md §11 "Network flag" and §7.2-C "Service fee";
# ClaudeCodeInstruction.md Phase 10; docs/DEPLOY.md for the full runbook.
#
# Local dev (running packages straight with `pnpm --filter <pkg> dev`,
# outside Docker) has its own env files and is not what this file is for:
# packages/web/.env.example (Vite reads from the package's own directory),
# testnet-services.env / devnet-services.env / offckb.env at the repo root.

# =====================================================================
# caddy — reverse proxy + static web build (packages/web/Dockerfile)
# =====================================================================

# Site address Caddy listens on. A real hostname gets automatic HTTPS
# (Let's Encrypt) on :443 plus an :80 -> :443 redirect. ":80" serves plain
# HTTP only on port 80, no ACME involved — use that for local/staging
# testing before DNS for your domain is ready. See docs/DEPLOY.md.
CADDY_DOMAIN=vericell.net
# CADDY_DOMAIN=:80

# --- Web build args (baked in at `docker compose build`, not runtime) ------
# The site's default network on first visit — every build still ships the
# in-browser testnet<->mainnet toggle (Phase 10b); this only sets which
# side it opens on. A public production deploy should be mainnet.
VITE_VERICELL_NETWORK=mainnet
# Public origin the browser calls for /api/v1/... — same origin as
# CADDY_DOMAIN in this stack (Caddy reverse-proxies /api to the api
# service), so this should normally just be "https://<CADDY_DOMAIN>".
# Required: the web app refuses to make any API call at all if unset.
VITE_API_URL=https://vericell.net
# Mirrors VERICELL_FEE_ADDRESS_TESTNET/MAINNET below so the browser-built
# anchor transaction can top up the same fee-collection pool. Unset = no
# fee shown or charged for that network in the web app. Never a real
# address in this file — see "Service fee" below and docs/DEPLOY.md.
VITE_VERICELL_FEE_ADDRESS_TESTNET=ckt1...YOUR_FEE_ADDRESS
VITE_VERICELL_FEE_ADDRESS_MAINNET=ckb1...YOUR_FEE_ADDRESS

# =====================================================================
# api — dual-network REST API (packages/api/Dockerfile, `api` service)
# =====================================================================
# One process serves BOTH testnet and mainnet at once (Phase 10a): this
# just picks which network gets the bare /api/v1/... alias. Both
# /api/v1/testnet/... and /api/v1/mainnet/... are always mounted.
VERICELL_NETWORK=mainnet

# Overrides the RPC endpoint for BOTH networks in this process (self-hosted
# node, private gateway, ...) — there is no way to point only one of
# testnet/mainnet at a custom node within the single dual-network `api`
# container; a per-network override would need two separate processes.
# Unset (the production default) = CCC's public testnet/mainnet endpoints.
VERICELL_RPC_URL=

PORT=3000
LOG_LEVEL=info

# Bearer token guarding POST /api/v1/keys (key minting). Required — unset
# means that route always 500s rather than accepting any caller.
ADMIN_TOKEN=

# SSRF guard on POST /webhooks and each delivery attempt denies URLs that
# resolve to a private/loopback/link-local address. 1|true to bypass —
# local testing only; never set this in production.
WEBHOOK_ALLOW_PRIVATE_NETWORKS=

# =====================================================================
# Service fee (TECHNICAL.md §7.2-C) — read by api, chain (via the CLI and
# scripts/), and the web build above.
# =====================================================================
# Fee recipient per network — 1% of a new proof cell's locked capacity,
# waived below 300 CKB. Unset = fee collection fully disabled on that
# network (the default). Never a real address in this file — fill in your
# own before deploying. `create-fee-cells --print-acp-address` derives the
# actual ACP collection address this maps to; fund it with
# `create-fee-cells` before turning this on for real (docs/DEPLOY.md's
# "Fee-cell setup" section) — an anchor on a network with no funded pool
# cell fails at broadcast once a fee is due.
VERICELL_FEE_ADDRESS_TESTNET=ckt1...YOUR_FEE_ADDRESS
VERICELL_FEE_ADDRESS_MAINNET=ckb1...YOUR_FEE_ADDRESS

# =====================================================================
# indexer-testnet / indexer-mainnet (packages/api/Dockerfile, `node
# dist/indexer/run.js`) — one single-network process per network, unlike
# the dual-network api service above.
# =====================================================================
POLL_INTERVAL_MS=3000
# First block to index when sync_state is empty, per network — set to
# VeriCell's actual first deployment height on each to skip walking from
# genesis. 0 = index from genesis (fine for a fresh testnet deploy; you
# almost always want a real value for mainnet before going live).
INDEXER_START_BLOCK_TESTNET=0
INDEXER_START_BLOCK_MAINNET=0

# =====================================================================
# Not used by this compose stack
# =====================================================================
# DB_PATH / DB_DIR: the compose stack always sets DB_DIR=/data (a named
# volume) for every service; dual-network mode (the api service) refuses
# to start at all if DB_PATH is also set (needs two DB files, not one) —
# see packages/api/src/server/run.ts. Nothing here to configure.
#
# VERICELL_DEVNET_RPC_URL, VERICELL_DEVNET_SCRIPTS_FILE, OFFCKB,
# VERICELL_OFFCKB_PRIVATE_KEY*: devnet/offckb is local-testing-and-CI-only
# (TECHNICAL.md §11) and is never deployed via this compose file — see
# offckb.env / devnet-services.env / scripts/e2e.sh instead.
STATS_TOKEN=
